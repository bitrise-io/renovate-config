{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": ["* 0-10 * * 1"],
  "automergeSchedule": ["* 0-10 * * 2"],
  "description": "Default Renovate configuration for Web Pillar repositories",
  "extends": [
    ":dependencyDashboard"
  ],
  "labels": ["renovate", "renovate-web-pillar-repositories"],
  "automergeType": "pr",
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "lockFileMaintenance",
        "rollback",
        "bump",
        "replacement"
      ],
      "groupName": "all non-major updates"
    },
    {
      "enabled": true,
      "matchDepTypes": ["indirect"],
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "groupName": null
    },
    {
      "enabled": true,
      "matchDepTypes": ["indirect"],
      "matchManagers": ["gomod"],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "lockFileMaintenance",
        "rollback",
        "bump",
        "replacement"
      ],
      "groupName": "all non-major updates"
    },
    {
      "matchDatasources": ["rubygems"],
      "addLabels": ["rubygem"],
      "groupName": "ruby gems"
    },
    {
      "matchDatasources": ["go"],
      "addLabels": ["go"],
      "groupName": "go modules"
    },
    {
      "matchDatasources": ["npm"],
      "addLabels": ["npm"],
      "groupName": "npm packages"
    },
    {
      "matchDatasources": ["node"],
      "addLabels": ["node"],
      "groupName": "node"
    },
    {
      "matchDatasources": ["ruby"],
      "addLabels": ["ruby"],
      "groupName": "ruby"
    },
    {
      "matchUpdateTypes": ["major"],
      "groupName": null
    },
    {
      "description": "Group family/monorepo packages into one PR (placed after the major->null rule so it also applies to majors).",
      "matchDatasources": ["rubygems"],
      "matchPackageNames": ["rubocop", "rubocop-*"],
      "groupName": "rubocop",
      "addLabels": ["rubygem"]
    },
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": ["@babel/**"],
      "groupName": "babel",
      "addLabels": ["npm"]
    },
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": ["storybook", "@storybook/**"],
      "groupName": "storybook",
      "addLabels": ["npm"]
    },
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": ["@datadog/browser-*"],
      "groupName": "datadog-browser",
      "addLabels": ["npm"]
    },
    {
      "automerge": true,
      "matchUpdateTypes": ["patch"]
    },
    {
      "automerge": true,
      "matchDatasources": ["go"],
      "matchUpdateTypes": ["minor"]
    }
  ],
  "postUpdateOptions": ["gomodTidy"],
  "rebaseWhen": "auto",
  "transitiveRemediation": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["website-security"]
  }
}
