{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": ["on Monday at 04:00"],
  "automergeSchedule": ["at 10am on Monday"],
  "description": "Default Renovate configuration for Web Pillar repositories",
  "extends": [
    ":dependencyDashboard"
  ],
  "labels": ["renovate", "renovate-web-pillar-repositories"],
  "automergeType": "pr",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "lockFileMaintenance",
        "rollback",
        "bump",
        "replacement"
      ],
      "groupName": "all non-major updates"
    },
    {
      "enabled": true,
      "matchDepTypes": ["indirect"],
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "groupName": null
    },
    {
      "enabled": true,
      "matchDepTypes": ["indirect"],
      "matchManagers": ["gomod"],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "pinDigest",
        "digest",
        "lockFileMaintenance",
        "rollback",
        "bump",
        "replacement"
      ],
      "groupName": "all non-major updates"
    },
    {
      "matchDatasources": ["rubygems"],
      "addLabels": ["rubygem"],
      "groupName": "ruby gems"
    },
    {
      "matchDatasources": ["go"],
      "addLabels": ["go"],
      "groupName": "go modules"
    },
    {
      "matchDatasources": ["npm"],
      "addLabels": ["npm"],
      "groupName": "npm packages"
    },
    {
      "matchDatasources": ["node"],
      "addLabels": ["node"],
      "groupName": "node"
    },
    {
      "matchDatasources": ["ruby"],
      "addLabels": ["ruby"],
      "groupName": "ruby"
    },
    {
      "matchUpdateTypes": ["major"],
      "groupName": null
    },
    {
      "automerge": true,
      "matchUpdateTypes": ["patch"]
    },
    {
      "automerge": true,
      "matchDatasources": ["go"],
      "matchUpdateTypes": ["minor"]
    }
  ],
  "postUpdateOptions": ["gomodTidy"],
  "rebaseWhen": "auto",
  "transitiveRemediation": true,
  "vulnerabilityAlerts": {
    "automerge": false,
    "enabled": true,
    "labels": ["website-security"]
  }
}
